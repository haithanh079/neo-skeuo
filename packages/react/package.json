{
  "name": "@neo-skeuo/react",
  "version": "1.1.2",
  "description": "Neo-skeuo React primitives for web",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "CHANGELOG.md",
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@neo-skeuo/tokens": "1.1.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@neo-skeuo/web-css": "1.1.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "jsdom": "^25.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "author": "haithanh079",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haithanh079/neo-skeuo.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/haithanh079/neo-skeuo/issues"
  },
  "homepage": "https://github.com/haithanh079/neo-skeuo/tree/master/packages/react#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "components",
    "design-system",
    "neo-skeuo",
    "react",
    "skeuomorphism",
    "theme",
    "ui"
  ]
