{
  "name": "@neo-skeuo/tokens",
  "version": "1.1.2",
  "description": "Neo-skeuo design tokens (light/dark) and theme serializers",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./tokens.json": "./tokens.json"
  },
  "files": [
    "CHANGELOG.md",
    "README.md",
    "dist",
    "tokens.json"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "author": "haithanh079",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haithanh079/neo-skeuo.git",
    "directory": "packages/tokens"
  },
  "bugs": {
    "url": "https://github.com/haithanh079/neo-skeuo/issues"
  },
  "homepage": "https://github.com/haithanh079/neo-skeuo/tree/master/packages/tokens#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "antd-theme",
    "css-variables",
    "design-system",
    "design-tokens",
    "neo-skeuo",
    "skeuomorphism",
    "theme",
    "ui"
  ]
}
