{
  "name": "@neo-skeuo/antd",
  "version": "1.1.0",
  "description": "Neo-skeuo Ant Design 5 provider and theme",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "antd": ">=5",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@neo-skeuo/tokens": "1.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "antd": "^5.29.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
