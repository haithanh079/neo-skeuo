    "@refinedev/core": ">=4",
    "antd": ">=5",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@neo-skeuo/antd": "0.1.0-alpha.0"
  },
  "devDependencies": {
    "@refinedev/core": "^4.57.0",
    "@types/react": "^18.3.18",
    "antd": "^5.29.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
